# ---------------------------------------------------------------------------
# Supabase — required
# ---------------------------------------------------------------------------
# Cloud project URL and anon/publishable key from the Supabase dashboard
# (Settings → API). On the Tabby network, dev uses the cloud project directly
# — see docs/ARCHITECTURE.md → "The Tabby network TLS issue".
#
# Two projects exist: bash-os-dev for local iteration, bash-os for production.
# .env.local should point at bash-os-dev (ref: xuqpifhojipuzqrowadt) so prompt
# tweaks and schema experiments don't pollute prod. Vercel env vars point at
# bash-os (ref: vbooingflkmzxcqnbvxr). See docs/ARCHITECTURE.md → "Dev / prod
# Supabase split" for the full workflow.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. Server-only. Used by the cron job to bypass RLS when
# fanning out per-user syncs. Never expose client-side. Use the DEV project's
# key locally; the prod key lives in Vercel env vars only.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google OAuth — required
# ---------------------------------------------------------------------------
# OAuth 2.0 Web client from Google Cloud Console. Used by
# /connectors/google/connect to start the OAuth dance and by
# src/lib/google/token.ts to refresh access tokens.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Gemini — required
# ---------------------------------------------------------------------------
# Direct Google Generative Language API key from
# https://aistudio.google.com/apikey. Used by the chat agent, daily brief,
# and memory embeddings via @ai-sdk/google.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Daily brief cron — required
# ---------------------------------------------------------------------------
# Random string. Vercel Cron sends it as Authorization: Bearer <value> to
# /api/cron/daily-brief. Any other value is rejected with 401.
CRON_SECRET=

# ---------------------------------------------------------------------------
# Jira connector — optional (skip to disable Jira sync silently)
# ---------------------------------------------------------------------------
# Atlassian site root, no trailing slash.
JIRA_BASE_URL=https://your-site.atlassian.net
# Atlassian login email (the one paired with the API token).
JIRA_EMAIL=
# Personal API token from
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ---------------------------------------------------------------------------
# Slack connector — optional (skip to disable Slack sync silently)
# ---------------------------------------------------------------------------
# User OAuth token (xoxp-...) from a Slack workspace app with scopes
# im:history, im:read, users:read. Currently blocked at Tabby — see
# docs/KNOWN_ISSUES.md #4.
SLACK_USER_TOKEN=
